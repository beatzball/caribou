# Litro: generated files (overwritten on every build; contain machine-local absolute paths)
apps/*/routes.generated.ts
apps/*/server/stubs/

# Build-time metadata: regenerated by scripts/write-build-meta.mjs before
# every dev/build/test/typecheck; checking it in would dirty git on every
# HEAD change. Anything running typecheck or tests goes through pnpm scripts
# which run write-build-meta first.
apps/*/server/build-meta.generated.ts
