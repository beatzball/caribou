{
  "name": "caribou-elena",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "imports": {
    "#litro/page-manifest": "./server/stubs/page-manifest.ts"
  },
  "scripts": {
    "build-meta": "node scripts/write-build-meta.mjs && node scripts/write-tokens-head.mjs",
    "dev": "pnpm build-meta && litro dev",
    "dev:portless": "pnpm build-meta && portless run litro dev",
    "build": "pnpm build-meta && litro build",
    "preview": "litro preview",
    "preview:portless": "portless run litro preview",
    "generate": "litro generate",
    "typecheck": "pnpm build-meta && tsc --noEmit",
    "lint": "eslint .",
    "test": "pnpm build-meta && vitest run",
    "test:coverage": "pnpm build-meta && vitest run --coverage",
    "test:e2e": "pnpm build-meta && playwright test"
  },
  "dependencies": {
    "@beatzball/litro": "latest",
    "@beatzball/litro-router": "^0.1.8",
    "@beatzball/caribou-auth": "workspace:*",
    "@beatzball/caribou-mastodon-client": "workspace:*",
    "@beatzball/caribou-state": "workspace:*",
    "@beatzball/caribou-design-tokens": "workspace:*",
    "@elenajs/core": "^1.0.0",
    "@elenajs/ssr": "^1.0.0-alpha.10",
    "@preact/signals-core": "^1.8.0",
    "dompurify": "^3.1.0",
    "h3": "^1.13.0",
    "masto": "^7.0.0",
    "unstorage": "^1.10.0"
  },
  "devDependencies": {
    "@beatzball/caribou-eslint-config": "workspace:*",
    "@beatzball/caribou-tsconfig": "workspace:*",
    "@playwright/test": "^1.48.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@axe-core/playwright": "^4.10.0",
    "@types/dompurify": "^3.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^15.0.0",
    "msw": "^2.6.0",
    "nitropack": "^2.13.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  }
}
